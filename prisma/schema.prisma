generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                     String   @id @default(cuid())
  name                   String
  isActive               Boolean  @default(true)
  modelConfig            String   @default("{}")
  writingStyle           String   @default("{}")
  wechatConfig           String   @default("{}")
  juejinConfig           String   @default("{}")
  defaultPublishPlatform String   @default("wechat")
  qualityConfig          String   @default("{\"minScore\":7.0,\"maxWriteRetries\":2}") // {minScore, maxWriteRetries}
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  contents       Content[]
  topics         Topic[]
  taskRuns       TaskRun[]
  schedules      ScheduledTask[]
  qualityRecords QualityRecord[]
  wallpapers     Wallpaper[]
}

model Topic {
  id        String      @id @default(cuid())
  accountId String
  account   Account     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  title     String
  angle     String      @default("")
  summary   String      @default("")
  sources   String      @default("[]")
  heatScore Float       @default(0)
  // V2 新增字段
  valueScore        Float       @default(0)    // 价值洼地评分
  redSeaLevel       String      @default("MEDIUM") // LOW | MEDIUM | HIGH
  contrarianAngle   String      @default("")   // 反共识策略说明
  timeToMainstream  String      @default("WEEKS") // NOW | WEEKS | MONTHS
  selectionStrategy String      @default("")   // VALUE_CREVASSE | EARLY_SIGNAL | CONTRARIAN
  tags      String      @default("[]")
  status    TopicStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  contents Content[]

  @@index([accountId, status])
}

enum TopicStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

model Content {
  id                  String        @id @default(cuid())
  accountId           String
  account             Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  topicId             String?
  topic               Topic?        @relation(fields: [topicId], references: [id], onDelete: SetNull)
  title               String        @default("")
  body                String        @default("")
  summary             String        @default("")
  wordCount           Int           @default(0)
  status              ContentStatus @default(DRAFT)
  reviewNotes         String        @default("")
  images              String        @default("[]") // JSON array of {alt, caption, base64}
  writerPromptVersion String        @default("")
  wechatMediaId       String?
  publishRecords      String        @default("[]") // JSON array of publish records
  publishedAt         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([accountId, status])
}

enum ContentStatus {
  DRAFT
  REVIEWING
  READY
  PUBLISHED
  REJECTED
}

model TaskRun {
  id         String    @id @default(cuid())
  accountId  String
  account    Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  taskType   TaskType
  status     RunStatus @default(RUNNING)
  input      String    @default("{}")
  output     String    @default("{}")
  error      String?
  durationMs Int?
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  /** Parent TaskRun ID. Non-null for steps run as part of a FULL_PIPELINE. */
  parentRunId String?
  parent      TaskRun?  @relation("TaskRunChildren", fields: [parentRunId], references: [id], onDelete: SetNull)
  children    TaskRun[] @relation("TaskRunChildren")

  @@index([accountId, taskType])
  @@index([parentRunId])

  verificationReports VerificationReport[]
}

enum TaskType {
  TREND_CRAWL
  TOPIC_SELECT
  RESEARCH
  WRITE
  GENERATE_IMAGES
  REVIEW
  PUBLISH
  FULL_PIPELINE
}

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

model ScheduledTask {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  taskType  TaskType
  cronExpr  String
  config    String   @default("{}")
  isEnabled Boolean  @default(true)
  lastRunAt DateTime?
  nextRunAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tracks review scores over time for quality monitoring.
model QualityRecord {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  topicId        String?
  contentId      String?
  score          Float    // Review score (0-10)
  passed         Boolean
  issues         String   @default("[]") // JSON array of issue strings
  suggestions    String   @default("[]") // JSON array of suggestion strings
  wordCount      Int      @default(0)
  imageCount           Int      @default(0)
  writeAttempts        Int      @default(1) // How many write attempts before passing
  writerPromptVersion  String   @default("") // Version of writer prompt used
  createdAt            DateTime @default(now())

  @@index([accountId, createdAt])
}

// Per-step quality verification reports for the expert skill system.
model VerificationReport {
  id         String   @id @default(cuid())
  taskRunId  String?
  taskRun    TaskRun? @relation(fields: [taskRunId], references: [id], onDelete: SetNull)
  step       String   // StepType / TaskType value
  status     String   // VerificationStatus: PASS/FAIL/WARN/SKIP
  inputData  String   @default("{}")  // JSON
  outputData String   @default("{}")  // JSON
  issues     String   @default("[]")  // JSON array
  warnings   String   @default("[]")  // JSON array
  score      Float?
  durationMs Int?
  retryCount Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([step, status])
  @@index([taskRunId])
}

// RSS feed sources for trend crawling.
// Can be managed per account or globally. If accountId is null, it's a global source.
model RssSource {
  id          String   @id @default(cuid())
  accountId   String?  // null means global source
  name        String   // Display name (e.g., "36Kr")
  url         String   // RSS feed URL
  category    String   @default("tech") // Category: tech, business, ai, dev, startup, etc.
  isEnabled   Boolean  @default(true)
  priority    Int      @default(0) // Higher priority sources are crawled first
  lastFetched DateTime?
  itemCount   Int      @default(0) // Number of items fetched in last crawl
  error       String?  // Last error message if fetch failed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId, isEnabled])
  @@index([category, isEnabled])
}

// 壁纸生成任务和结果
model Wallpaper {
  id            String          @id @default(cuid())
  accountId     String?
  account       Account?        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name          String          // 壁纸名称/主题
  prompt        String          // 生成提示词
  aspectRatio   String          @default("9:16") // 1:1, 16:9, 9:16, 4:3, 3:4
  status        WallpaperStatus @default(PENDING)
  imageUrl      String?         // 生成的图片路径/URL
  fileSize      Int?            // 文件大小(bytes)
  width         Int?            // 图片宽度
  height        Int?            // 图片高度
  tags          String          @default("[]") // JSON array of tags
  isFavorite    Boolean         @default(false)
  downloadCount Int             @default(0)
  error         String?         // 错误信息
  taskRunId     String?         // 关联的任务运行ID
  generatedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([accountId, status])
  @@index([accountId, isFavorite])
  @@index([createdAt])
}

enum WallpaperStatus {
  PENDING    // 等待生成
  GENERATING // 生成中
  COMPLETED  // 已完成
  FAILED     // 失败
}
