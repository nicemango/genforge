{
  "$schema": "../config/llm-providers.schema.json",
  "_comment": "Research Agent 配置 - 模型通过 llm-providers.json 统一管理",

  "provider": "volcengine-kimi",
  "agent": {
    "maxSteps": 60,
    "temperature": 0.3,
    "maxTokens": 16000,
    "searchRetry": 3,
    "fetchRetry": 3
  },
  "quality": {
    "minDataPoints": 8,
    "minCases": 3,
    "minExpertQuotes": 3,
    "minControversies": 2
  }
}
